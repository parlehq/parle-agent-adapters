{
  "name": "@parlehq/mcp-server",
  "version": "0.1.12",
  "private": true,
  "type": "module",
  "bin": {
    "parle-mcp": "./dist/parle-mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/parle-mcp.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@parlehq/agent-client": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
