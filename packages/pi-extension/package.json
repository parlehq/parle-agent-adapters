{
  "name": "@parlehq/pi-extension",
  "version": "0.1.18",
  "private": true,
  "type": "module",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.4 <0.81.0",
    "typebox": "*"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --external:typebox --outfile=dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node scripts/check-pi-artifact.mjs && node --test test/*.test.mjs"
  },
  "devDependencies": {
    "jiti": "^2.7.0",
    "typebox": "^1.0.0",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@parlehq/agent-client": "workspace:*"
  }
}
